[project]
name = "__ALCHEMIQ_DIST__"
version = "0.1.0"
requires-python = ">=3.12"
dependencies = [
    "alchemiq[__ALCHEMIQ_EXTRAS__]>=0.1",
    "uvicorn>=0.30",  # alchemiq:if fastapi
    "faststream[rabbit,cli]>=0.5",  # alchemiq:if faststream
]

[dependency-groups]
dev = [
    "pytest>=8",
    "anyio>=4",
    "ruff>=0.8",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/__ALCHEMIQ_MODULE__"]

[tool.pytest.ini_options]
testpaths = ["tests"]
# importlib mode keeps same-named test files from colliding when several
# workspace services are collected in one pytest run.
addopts = "--import-mode=importlib"

[tool.alchemiq]
models = ["__ALCHEMIQ_MODULE__.domain.models"]

# alchemiq:block postgres
[tool.alchemiq.postgres]
host = "${POSTGRES_HOST}"
port = "${POSTGRES_PORT}"
database = "${POSTGRES_DB}"  # alchemiq:ifnot monorepo
database = "__ALCHEMIQ_MODULE__"  # alchemiq:if monorepo
username = "${POSTGRES_USER}"
password = "${POSTGRES_PASSWORD}"
# alchemiq:endblock
# alchemiq:block clickhouse
[tool.alchemiq.clickhouse]
host = "${CLICKHOUSE_HOST}"
port = "${CLICKHOUSE_PORT}"
database = "${CLICKHOUSE_DB}"
username = "${CLICKHOUSE_USER}"
password = "${CLICKHOUSE_PASSWORD}"
# alchemiq:endblock

[tool.ruff.lint.isort]
known-first-party = ["__ALCHEMIQ_MODULE__"]
