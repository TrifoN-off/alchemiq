# Copy to .env (cp .env.example .env) - per-service commands load it
# via `uv run --env-file ../../.env ...`.
# alchemiq:block postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Admin/default database only. Each Postgres-backed service uses its own
# database named after its module (created by docker/postgres-init.sh).
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
# alchemiq:endblock
# alchemiq:block clickhouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=app
CLICKHOUSE_USER=app
CLICKHOUSE_PASSWORD=app
# alchemiq:endblock
BROKER_URL=amqp://guest:guest@localhost:5672/  # alchemiq:if faststream
REDIS_URL=redis://localhost:6379/0  # alchemiq:if redis
